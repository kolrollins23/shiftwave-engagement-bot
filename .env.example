# ── Auth ───────────────────────────────────────────────────────────────────────
# Password for the web app login page.
# Anyone who knows this can send notifications — keep it internal.
APP_PASSWORD=change-me

# ── Twilio ─────────────────────────────────────────────────────────────────────
# From console.twilio.com → Account Info (top of dashboard)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# The phone number Twilio gave you (buy one in the console, ~$1.15/mo)
TWILIO_FROM_NUMBER=+15557654321

# ── Optional: AI comment suggestions ──────────────────────────────────────────
# Leave blank to send plain SMS without comment ideas.
ANTHROPIC_API_KEY=sk-ant-your-key-here
